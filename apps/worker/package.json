{
  "name": "@edgeintel/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run --outdir .wrangler/build",
    "typecheck": "npx tsc --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "validate:install": "bash scripts/validate-install.sh",
    "cf:types": "wrangler types",
    "cf:types:check": "bash scripts/check-worker-types.sh",
    "db:local:apply": "bash scripts/d1-local.sh apply",
    "db:local:list": "bash scripts/d1-local.sh list",
    "db:local:reset": "bash scripts/d1-local.sh reset",
    "verify": "npm run validate:install && npm run cf:types:check && npm run typecheck && npm run test && npm run deploy:dry-run"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.81.1"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@edgeintel/intelligence-rules": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.10.0",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  }
}
