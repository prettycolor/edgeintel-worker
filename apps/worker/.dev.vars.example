# Local development secrets for Wrangler.
# Copy to .dev.vars for local use. Do not commit the real file.

# Optional AI Gateway bearer token.
AI_GATEWAY_TOKEN=

# Optional upstream provider API key when AI Gateway is not using BYOK internally.
AI_UPSTREAM_API_KEY=

# Optional Browser Rendering REST token.
BROWSER_RENDERING_API_TOKEN=

# Optional Cloudflare API token for Tunnel, DNS, and Access orchestration.
CLOUDFLARE_API_TOKEN=

# Optional Cloudflare account identifier for account-scoped helpers.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Optional Cloudflare Access config for operator auth on the control plane.
ACCESS_TEAM_DOMAIN=
ACCESS_AUD=
ACCESS_ALLOW_DEV_BYPASS=false

# Optional Cloudflare Access for SaaS OAuth config for the authenticated MCP surface.
MCP_ACCESS_CLIENT_ID=
MCP_ACCESS_CLIENT_SECRET=
MCP_ACCESS_TOKEN_URL=
MCP_ACCESS_AUTHORIZATION_URL=
MCP_ACCESS_JWKS_URL=

# Optional pairing and connector token TTL overrides in seconds.
PAIRING_TOKEN_TTL_SECONDS=900
CONNECTOR_TOKEN_TTL_SECONDS=2592000

# Optional base64-encoded 32-byte encryption key for provider secret storage.
PROVIDER_SECRET_ENCRYPTION_KEY=

# Optional self-hosted model path. This must be HTTPS in deployed Worker use.
LOCAL_MODEL_GATEWAY_URL=
LOCAL_MODEL_MODEL=
LOCAL_MODEL_API_KEY=
LOCAL_MODEL_ACCESS_CLIENT_ID=
LOCAL_MODEL_ACCESS_CLIENT_SECRET=
LOCAL_MODEL_AI_GATEWAY_PROVIDER=
